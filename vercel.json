{
  "buildCommand": "echo 'No build needed for static site'",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/offer-trial",
      "destination": "/offer-trial.html"
    },
    {
      "source": "/thank-you",
      "destination": "/thank-you/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
